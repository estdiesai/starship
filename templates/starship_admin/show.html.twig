{% extends 'base.html.twig' %}

{% block title %}Starship{% endblock %}

{% block body %}
    <h1>Starship</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ starship.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ starship.name }}</td>
            </tr>
            <tr>
                <th>Class</th>
                <td>{{ starship.class }}</td>
            </tr>
            <tr>
                <th>Captain</th>
                <td>{{ starship.captain }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>{{ starship.status.value }}</td>
            </tr>
            <tr>
                <th>ArrivedAt</th>
                <td>{{ starship.arrivedAt ? starship.arrivedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ starship.slug }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ starship.createdAt ? starship.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ starship.updatedAt ? starship.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_starship_admin_index') }}">back to list</a>

    <a href="{{ path('app_starship_admin_edit', {'id': starship.id}) }}">edit</a>

    {{ include('starship_admin/_delete_form.html.twig') }}
{% endblock %}
