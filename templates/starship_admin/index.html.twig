{% extends 'base.html.twig' %}

{% block title %}Starship index{% endblock %}

{% block body %}
    <h1>Starship index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Class</th>
                <th>Captain</th>
                <th>Status</th>
                <th>ArrivedAt</th>
                <th>Slug</th>
                <th>CreatedAt</th>
                <th>UpdatedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for starship in starships %}
            <tr>
                <td>{{ starship.id }}</td>
                <td>{{ starship.name }}</td>
                <td>{{ starship.class }}</td>
                <td>{{ starship.captain }}</td>
                <td>{{ starship.status.value }}</td>
                <td>{{ starship.arrivedAt ? starship.arrivedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ starship.slug }}</td>
                <td>{{ starship.createdAt ? starship.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ starship.updatedAt ? starship.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_starship_admin_show', {'id': starship.id}) }}">show</a>
                    <a href="{{ path('app_starship_admin_edit', {'id': starship.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="10">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_starship_admin_new') }}">Create new</a>
{% endblock %}
