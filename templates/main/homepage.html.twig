{% extends 'base.html.twig' %}

{# Si ponermos la línea de debajo cambia el título de base por este propio #}

{% block title %}
    {{ parent() }} Starshop: Beam up some parts!{% endblock %}

{% block body %}
<h1>
    Starshop: your monopoly-busting option for Starship parts!
</h1>

<div>
    Browse through {{ numberOfStarships * 10 }} starships!<br>{#matriz asociativa#}
    Browse through {{ ships|length *10}} starships!{#objeto#}

    {% if numberOfStarships > 400 %}
        <p>
            {# Do you think "shiploads" will pass the legal team? #}
            That's a shiploads of ships!
        </p>
    {% endif %}
    {% if ships|length > 2 %}
        <p> 
            That's a shipsloads of ships
        </p>
    {% endif %}
</div>

<div>
    <h2>My Ship</h2>

    <table>
        <tr>
            <th>Name</th>
            <td>
                <a href="{{path('app_starship_show', {
                    id:myShip.id })
                }}">
                {{ myShip.name }}</td></a>
        </tr>
        <tr>
            <th>Class</th>
            <td>{{ myShip.class }}</td>
        </tr>
        <tr>
            <th>Captain</th>
            <td>{{ myShip.captain|upper|lower|title }}</td>
        </tr>
        <tr>
            <th>Status</th>
            <td>{{ myShip.status }}</td>
        </tr>
    </table>
</div>
{% endblock %}